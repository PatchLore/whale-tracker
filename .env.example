NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
# Public URL for your Supabase project.

NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Public anon key for client-side Supabase access.

SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Service role key used on the server (webhooks, background jobs). Keep this secret.

ETHERSCAN_API_KEY=your-etherscan-api-key
# Etherscan API key for live Ethereum transaction polling.

NEXT_PUBLIC_APP_URL=http://localhost:3000
# Base URL for the app, used in auth callbacks and links.

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Bot token from BotFather for sending Telegram alerts.

STRIPE_SECRET_KEY=your-stripe-secret-key
# Stripe secret key for creating Checkout sessions and handling webhooks.

STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
# Stripe webhook signing secret from your Stripe dashboard.

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
# Stripe publishable key (if you later use client-side Stripe.js).

STRIPE_PRO_PRICE_ID=price_xxx
# Stripe Price ID for the WhaleNet Pro £9.99/month plan (GBP).

# Whop Integration
WHOP_API_KEY=apik_xxxxx
# Whop API key (server-only). Get from Whop Dashboard → Settings → API.
# Format: apik_XXXXX. NEVER expose this to the client.

WHOP_WEBHOOK_SECRET=ws_xxxxx
# Whop webhook signing secret. Get from Whop Dashboard.
# Used to verify incoming webhook signatures. Format: ws_XXXXX.

NEXT_PUBLIC_WHOP_APP_ID=app_xxxxx
# Whop App ID. Get from Product → App Settings.
# Format: app_XXXXX. Used for token verification.

NEXT_PUBLIC_WHOP_COMPANY_ID=biz_xxxxx
# Whop Business/Company ID. Get from Dashboard → Settings → API.
# Format: biz_XXXXX. Used for access/membership checks.

WHOP_EXPERIENCE_SLUG=whalenet-2e
# URL slug for the Whop experience. Used in /experiences/[slug] redirects.
# Default: whalenet-2e. Change if your experience has a different slug.

WHOP_STORE_URL=https://whop.com/whalenet-2e/
# Full URL to your Whop store/subscription page.
# Used in subscribe buttons and links throughout the app.

NEXT_PUBLIC_REVIEW_MODE=false
# Set to "true" to bypass access checks for app reviewers.
# IMPORTANT: Set to "false" or remove entirely after approval.