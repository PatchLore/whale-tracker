NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
# Public URL for your Supabase project.

NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Public anon key for client-side Supabase access.

SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Service role key used on the server (webhooks, background jobs). Keep this secret.

ETHERSCAN_API_KEY=your-etherscan-api-key
# Etherscan API key for live Ethereum transaction polling.

NEXT_PUBLIC_APP_URL=http://localhost:3000
# Base URL for the app, used in auth callbacks and links.

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Bot token from BotFather for sending Telegram alerts.

STRIPE_SECRET_KEY=your-stripe-secret-key
# Stripe secret key for creating Checkout sessions and handling webhooks.

STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
# Stripe webhook signing secret from your Stripe dashboard.

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
# Stripe publishable key (if you later use client-side Stripe.js).

STRIPE_PRO_PRICE_ID=price_xxx
# Stripe Price ID for the WhaleNet Pro £9.99/month plan (GBP).

